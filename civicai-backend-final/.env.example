# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/civicai
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/civicai

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_32char_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── Anthropic Claude API ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-real-key-here

# ─── File Upload ──────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/jpg

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
REPORT_DAILY_LIMIT=3

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
